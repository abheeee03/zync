generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum WORFLOWRUN_STATUS {
    PENDING
    FAILED
    RUNNING
    SUCCESS
}

model User {
    id            String      @id
    name          String
    email         String      @unique
    emailVerified Boolean
    image         String?
    createdAt     DateTime    @db.Timestamptz(3)
    updatedAt     DateTime    @db.Timestamptz(3)
    workflow      Workflows[]
    session       Session[]
    account       Account[]

    @@map("user")
}

model Session {
    id        String   @id
    user      User     @relation(fields: [userId], references: [id])
    userId    String
    token     String   @unique
    expiresAt DateTime @db.Timestamptz(3)
    ipAddress String?
    userAgent String?
    createdAt DateTime @db.Timestamptz(3)
    updatedAt DateTime @db.Timestamptz(3)

    @@map("session")
}

model Account {
    id                    String    @id
    user                  User      @relation(fields: [userId], references: [id])
    userId                String
    accountId             String
    providerId            String
    accessToken           String?
    refreshToken          String?
    accessTokenExpiresAt  DateTime? @db.Timestamptz(3)
    refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
    scope                 String?
    idToken               String?
    password              String?
    createdAt             DateTime  @db.Timestamptz(3)
    updatedAt             DateTime  @db.Timestamptz(3)

    @@map("account")
}

model Verification {
    id         String   @id
    identifier String
    value      String
    expiresAt  DateTime @db.Timestamptz(3)
    createdAt  DateTime @db.Timestamptz(3)
    updatedAt  DateTime @db.Timestamptz(3)

    @@map("verification")
}

model Workflows {
    id           String        @id @default(uuid())
    name         String?       @default("Untitled")
    userId       String
    isActive     Boolean       @default(true)
    nodes        Json          @default("[]")
    edges        Json          @default("[]")
    createdAt    DateTime      @default(now())
    trigger      Trigger?
    actions      Action[]
    user         User          @relation(references: [id], fields: [userId])
    workflowRuns WorkflowRun[]
}

model WorkflowRun {
    id           String            @id @default(uuid())
    workflowId   String
    current_step Int               @default(0)
    created_at   DateTime          @default(now())
    status       WORFLOWRUN_STATUS @default(PENDING)
    workflow     Workflows         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Trigger {
    id               String            @id @default(uuid())
    userId           String
    triggerId        String
    workflowId       String            @unique
    metaData         Json              @default("{}")
    availbleTriggers AvailableTriggers @relation(references: [id], fields: [triggerId])
    workflow         Workflows         @relation(references: [id], fields: [workflowId], onDelete: Cascade)
}

model Action {
    id         String           @id @default(uuid())
    actionId   String
    workflowId String
    order      Int              @default(0)
    metaData   Json             @default("{}")
    action     AvailableActions @relation(references: [id], fields: [actionId])
    workflow   Workflows        @relation(references: [id], fields: [workflowId], onDelete: Cascade)
}

model AvailableTriggers {
    id      String    @id @default(uuid())
    name    String
    trigger Trigger[]
}

model AvailableActions {
    id     String   @id @default(uuid())
    name   String
    action Action[]
}
